{
  "manifest_version": 3,
  "name": "Vakshiksha AI Video Dubbing",
  "version": "1.0.0",
  "description": "Dub any video on the web into 13+ languages with AI. Requires Vakshiksha Pro.",
  "permissions": ["activeTab", "storage", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon128.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "48": "icon128.png",
    "128": "icon128.png"
  },
  "host_permissions": ["<all_urls>"]
}
